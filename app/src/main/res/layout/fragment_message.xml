<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MessageFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/messageHeaderContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:paddingTop="6dp"
        android:paddingEnd="4dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/messageButtonBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_back"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back_black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/messageButtonAddFriend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_add_friend"
            android:padding="8dp"
            android:src="@drawable/ic_add_friend"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/messageTabsRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/messageButtonAddFriend"
            app:layout_constraintStart_toEndOf="@id/messageButtonBack"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tabMessageContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tabFriendsContainer"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tabMessageLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/message_tab_message"
                    android:textColor="@color/black"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/tabMessageIndicator"
                    android:layout_width="28dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/terabox_blue"
                    app:layout_constraintTop_toBottomOf="@id/tabMessageLabel" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tabFriendsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tabMessageContainer"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tabFriendsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/message_tab_friends"
                    android:textColor="@color/files_tab_muted"
                    android:textSize="17sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/tabFriendsIndicator"
                    android:layout_width="28dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="6dp"
                    android:background="@android:color/transparent"
                    app:layout_constraintTop_toBottomOf="@id/tabFriendsLabel" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/messageHeaderDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/message_divider"
        app:layout_constraintTop_toBottomOf="@id/messageHeaderContainer" />

    <FrameLayout
        android:id="@+id/messageContentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/messageHeaderDivider">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/messageScrollContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/messageListSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="24dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/messageRow1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <FrameLayout
                        android:id="@+id/row1IconBg"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_message_icon_teal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_message_bell_white" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/row1Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:text="@string/message_in_app_title"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/row1MetaColumn"
                        app:layout_constraintStart_toEndOf="@id/row1IconBg"
                        app:layout_constraintTop_toTopOf="@id/row1IconBg" />

                    <TextView
                        android:id="@+id/row1Subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="@string/message_in_app_subtitle"
                        android:textColor="@color/files_tab_muted"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toStartOf="@id/row1MetaColumn"
                        app:layout_constraintStart_toEndOf="@id/row1IconBg"
                        app:layout_constraintTop_toBottomOf="@id/row1Title" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/row1MetaColumn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/row1IconBg">

                        <TextView
                            android:id="@+id/row1Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/message_sample_time"
                            android:textColor="@color/files_tab_muted"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/row1Badge"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_badge_red"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/row1Time" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:id="@+id/messageDivider1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="84dp"
                    android:background="@color/message_divider"
                    app:layout_constraintTop_toBottomOf="@id/messageRow1" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/messageRow2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp"
                    app:layout_constraintTop_toBottomOf="@id/messageDivider1">

                    <FrameLayout
                        android:id="@+id/row2IconBg"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_message_icon_blue"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_message_group_white" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/row2Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:text="@string/message_new_friends_title"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/row2IconBg"
                        app:layout_constraintTop_toTopOf="@id/row2IconBg" />

                    <TextView
                        android:id="@+id/row2Subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/message_new_friends_subtitle"
                        android:textColor="@color/files_tab_muted"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/row2IconBg"
                        app:layout_constraintTop_toBottomOf="@id/row2Title" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:id="@+id/messageDivider2"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/message_divider"
                    app:layout_constraintTop_toBottomOf="@id/messageRow2" />

                <TextView
                    android:id="@+id/messageFooter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingTop="36dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="8dp"
                    android:text="@string/message_footer_bottom"
                    android:textColor="@color/message_footer_muted"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/messageDivider2" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/friendsEmptySection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/message_friends_empty"
                android:textColor="@color/files_tab_muted"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
